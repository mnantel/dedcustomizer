<Window x:Class="DcsDedGui.FieldBrowserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Browse DCS Fields"
        Width="620" Height="520"
        MinWidth="420" MinHeight="300"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Filter -->
            <RowDefinition Height="*"/>     <!-- Grid -->
            <RowDefinition Height="Auto"/>  <!-- Buttons -->
        </Grid.RowDefinitions>

        <!-- Filter row -->
        <Border Grid.Row="0" Padding="10,8" Background="#252526"
                BorderBrush="#3F3F46" BorderThickness="0,0,0,1">
            <DockPanel>
                <TextBlock Text="Filter:" Foreground="#AAAAAA" VerticalAlignment="Center"
                           Margin="0,0,8,0" DockPanel.Dock="Left"/>
                <TextBox x:Name="FilterBox" Background="#2D2D2D" Foreground="White"
                         BorderBrush="#555" CaretBrush="White" Padding="4,3"
                         TextChanged="FilterBox_TextChanged"/>
            </DockPanel>
        </Border>

        <!-- Key / Value grid -->
        <DataGrid x:Name="FieldsDataGrid" Grid.Row="1"
                  Background="#1E1E1E" Foreground="#CCCCCC"
                  BorderThickness="0"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="#2D2D2D"
                  RowBackground="#1E1E1E"
                  AlternatingRowBackground="#222222"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  HeadersVisibility="Column"
                  MouseDoubleClick="FieldsDataGrid_MouseDoubleClick">
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#2D2D2D"/>
                    <Setter Property="Foreground" Value="#AAAAAA"/>
                    <Setter Property="Padding" Value="8,4"/>
                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                    <Setter Property="BorderBrush" Value="#3F3F46"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>
            <DataGrid.CellStyle>
                <Style TargetType="DataGridCell">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="#CCCCCC"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#094771"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.CellStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Key" Binding="{Binding Key}" Width="*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontFamily" Value="Consolas"/>
                            <Setter Property="Foreground" Value="#DDDDDD"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Current Value" Binding="{Binding Value}" Width="200">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontFamily" Value="Consolas"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Footer buttons -->
        <Border Grid.Row="2" Padding="10,8" Background="#252526"
                BorderBrush="#3F3F46" BorderThickness="0,1,0,0">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left" Foreground="#666666" FontSize="11"
                           VerticalAlignment="Center"
                           Text="Double-click or select a key then click Add as Field."/>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Add as Field →" Click="AddAsField_Click" Padding="12,5"
                            Background="#0E639C" Foreground="White" BorderThickness="0"
                            Margin="0,0,8,0"/>
                    <Button Content="Cancel" Click="Cancel_Click" Padding="12,5"
                            Background="#3F3F46" Foreground="White" BorderThickness="0"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
