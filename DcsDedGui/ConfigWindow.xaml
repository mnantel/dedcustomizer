<Window x:Class="DcsDedGui.ConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:DcsDedGui"
        Title="WINCTRL DED Customizer"
        MinWidth="900" MinHeight="600"
        Width="1050" Height="700"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Status dot -->
        <Style x:Key="StatusDot" TargetType="Ellipse">
            <Setter Property="Width" Value="10"/>
            <Setter Property="Height" Value="10"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Status row label -->
        <Style x:Key="StatusLabel" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Foreground" Value="#BBBBBB"/>
            <Setter Property="Width" Value="115"/>
        </Style>

        <!-- Action button with visible disabled state -->
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="#333333"/>
                                <Setter Property="Foreground" Value="#666666"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1177BB"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#0A4F7A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Token chip -->
        <Style x:Key="TokenChip" TargetType="Border">
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Margin" Value="2,2"/>
            <Setter Property="Padding" Value="5,2"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- DataGrid cell style (dark) -->
        <Style x:Key="DarkCell" TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#094771"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Background="#1E1E1E">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Runtime status -->
            <RowDefinition Height="Auto"/>  <!-- DCS setup -->
            <RowDefinition Height="*"/>     <!-- Tabs -->
            <RowDefinition Height="Auto"/>  <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- ── Status bar ──────────────────────────────────────────────── -->
        <Border Grid.Row="0" Background="#252526" BorderBrush="#3F3F46"
                BorderThickness="0,0,0,1" Padding="12,8">
            <WrapPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                    <Ellipse Style="{StaticResource StatusDot}"
                             Fill="{Binding DedStatusBrush, RelativeSource={RelativeSource AncestorType=Window}}"/>
                    <TextBlock Style="{StaticResource StatusLabel}" Text="DED device:"/>
                    <TextBlock VerticalAlignment="Center" Foreground="White"
                               Text="{Binding DedStatusText, RelativeSource={RelativeSource AncestorType=Window}}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                    <Ellipse Style="{StaticResource StatusDot}"
                             Fill="{Binding UdpStatusBrush, RelativeSource={RelativeSource AncestorType=Window}}"/>
                    <TextBlock Style="{StaticResource StatusLabel}" Text="UDP port 7778:"/>
                    <TextBlock VerticalAlignment="Center" Foreground="White"
                               Text="{Binding UdpStatusText, RelativeSource={RelativeSource AncestorType=Window}}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Ellipse Style="{StaticResource StatusDot}"
                             Fill="{Binding DcsStatusBrush, RelativeSource={RelativeSource AncestorType=Window}}"/>
                    <TextBlock Style="{StaticResource StatusLabel}" Text="DCS:"/>
                    <TextBlock VerticalAlignment="Center" Foreground="White"
                               Text="{Binding DcsStatusText, RelativeSource={RelativeSource AncestorType=Window}}"/>
                </StackPanel>
            </WrapPanel>
        </Border>

        <!-- ── DCS Setup ───────────────────────────────────────────────── -->
        <Border Grid.Row="1" Background="#1E1E1E" BorderBrush="#3F3F46"
                BorderThickness="0,0,0,1" Padding="12,6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" Margin="0,0,0,4">
                    <TextBlock Text="DCS folder:" Foreground="#BBBBBB" Width="80"
                               VerticalAlignment="Center" DockPanel.Dock="Left"/>
                    <Button Content="Browse…" Click="BrowseDcsFolder_Click"
                            DockPanel.Dock="Right" Padding="8,2" Margin="6,0,0,0"
                            Background="#3F3F46" Foreground="White" BorderThickness="0"/>
                    <TextBox x:Name="DcsFolderBox"
                             Background="#2D2D2D" Foreground="#DDDDDD"
                             BorderBrush="#555" CaretBrush="White"
                             IsReadOnly="True" Padding="4,2"/>
                </DockPanel>

                <WrapPanel Grid.Row="1">
                    <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                        <Ellipse Style="{StaticResource StatusDot}"
                                 Fill="{Binding ScriptStatusBrush, RelativeSource={RelativeSource AncestorType=Window}}"/>
                        <TextBlock Style="{StaticResource StatusLabel}" Text="ded_bridge.lua:" Width="105"/>
                        <TextBlock VerticalAlignment="Center" Foreground="White" MinWidth="90"
                                   Text="{Binding ScriptStatusText, RelativeSource={RelativeSource AncestorType=Window}}"/>
                        <Button Content="Deploy" Click="DeployScript_Click"
                                Style="{StaticResource ActionButton}"
                                IsEnabled="{Binding CanDeployScript, RelativeSource={RelativeSource AncestorType=Window}}"
                                Padding="8,2" Margin="6,0,0,0"
                                Background="#0E639C"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Style="{StaticResource StatusDot}"
                                 Fill="{Binding ExportStatusBrush, RelativeSource={RelativeSource AncestorType=Window}}"/>
                        <TextBlock Style="{StaticResource StatusLabel}" Text="Export.lua:" Width="75"/>
                        <TextBlock VerticalAlignment="Center" Foreground="White" MinWidth="100"
                                   Text="{Binding ExportStatusText, RelativeSource={RelativeSource AncestorType=Window}}"/>
                        <Button Content="Fix Export.lua" Click="FixExport_Click"
                                Style="{StaticResource ActionButton}"
                                IsEnabled="{Binding CanFixExport, RelativeSource={RelativeSource AncestorType=Window}}"
                                Padding="8,2" Margin="6,0,0,0"
                                Background="#0E639C"/>
                    </StackPanel>
                </WrapPanel>
            </Grid>
        </Border>

        <!-- ── Tab area ────────────────────────────────────────────────── -->
        <TabControl Grid.Row="2" Background="#1E1E1E" BorderBrush="#3F3F46"
                    BorderThickness="0,1,0,0">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Background" Value="#2D2D2D"/>
                    <Setter Property="Foreground" Value="#AAAAAA"/>
                    <Setter Property="BorderBrush" Value="#3F3F46"/>
                    <Setter Property="Padding" Value="12,5"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border x:Name="Bd"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="1,1,1,0"
                                        Margin="0,0,2,0">
                                    <ContentPresenter ContentSource="Header"
                                                      Margin="{TemplateBinding Padding}"
                                                      TextElement.Foreground="{TemplateBinding Foreground}"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#1E1E1E"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter TargetName="Bd" Property="BorderBrush" Value="#3F3F46"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#333333"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>

            <!-- ════════════════ Tab 1: Aircraft Profiles ════════════════ -->
            <TabItem Header="Aircraft Profiles">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180" MinWidth="140"/>
                        <ColumnDefinition Width="5"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: aircraft list -->
                    <DockPanel Grid.Column="0" Background="#252526">
                        <Border DockPanel.Dock="Top" Padding="8,6" BorderBrush="#3F3F46" BorderThickness="0,0,0,1">
                            <TextBlock Text="Aircraft Profiles" Foreground="#CCCCCC" FontSize="11" FontWeight="SemiBold"/>
                        </Border>

                        <Border x:Name="AddPanel" DockPanel.Dock="Bottom" Visibility="Collapsed"
                                Background="#2D2D2D" Padding="6" BorderBrush="#3F3F46" BorderThickness="0,1,0,0">
                            <StackPanel>
                                <TextBlock Text="Aircraft name:" Foreground="#AAAAAA" FontSize="11" Margin="0,0,0,3"/>
                                <ComboBox x:Name="NewAircraftCombo" IsEditable="True"
                                          FontSize="11" Margin="0,0,0,4"/>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Add" Click="ConfirmAdd_Click" Padding="10,3"
                                            Background="#0E639C" Foreground="White" BorderThickness="0" Margin="0,0,4,0"/>
                                    <Button Content="Cancel" Click="CancelAdd_Click" Padding="10,3"
                                            Background="#3F3F46" Foreground="White" BorderThickness="0"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="4,4">
                            <Button Content="＋ Add" Click="ShowAddPanel_Click" Padding="8,3" Margin="0,0,4,0"
                                    Background="#0E639C" Foreground="White" BorderThickness="0"/>
                            <Button Content="－ Remove" Click="RemoveAircraft_Click" Padding="8,3"
                                    Background="#3F3F46" Foreground="White" BorderThickness="0"/>
                        </StackPanel>

                        <ListBox x:Name="AircraftList" Background="Transparent" BorderThickness="0"
                                 Foreground="#CCCCCC" SelectionChanged="AircraftList_SelectionChanged">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}" Padding="4,2"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>

                    <!-- Splitter -->
                    <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                                  Background="#3F3F46"/>

                    <!-- Right: profile editor -->
                    <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto"
                                  Background="#1E1E1E" Padding="12,8">
                        <StackPanel x:Name="EditorPanel">
                            <TextBlock x:Name="EmptyState" Text="Select an aircraft profile or add a new one."
                                       Foreground="#666" HorizontalAlignment="Center" Margin="0,40,0,0"
                                       FontSize="13"/>

                            <StackPanel x:Name="ProfileEditor" Visibility="Collapsed">
                                <TextBlock x:Name="ProfileNameLabel" FontSize="16" FontWeight="Bold"
                                           Foreground="White" Margin="0,0,0,10"/>

                                <GroupBox Header="DED Mode" Foreground="#AAAAAA" Margin="0,0,0,10"
                                          BorderBrush="#3F3F46">
                                    <StackPanel Margin="4,4">
                                        <RadioButton x:Name="ModeSkip"
                                                     Content="Skip — do not write to DED (e.g. WinWing already handles this aircraft)"
                                                     GroupName="Mode" Foreground="#CCCCCC"
                                                     Checked="Mode_Checked" Margin="0,2"/>
                                        <RadioButton x:Name="ModeDefault"
                                                     Content="Default — use the standard HDG / ALT / UHF / STPT / FM / FUEL layout"
                                                     GroupName="Mode" Foreground="#CCCCCC"
                                                     Checked="Mode_Checked" Margin="0,2"/>
                                        <RadioButton x:Name="ModeCustom"
                                                     Content="Custom — choose which fields appear on each line"
                                                     GroupName="Mode" Foreground="#CCCCCC"
                                                     Checked="Mode_Checked" Margin="0,2"/>
                                    </StackPanel>
                                </GroupBox>

                                <!-- Custom line editors -->
                                <GroupBox x:Name="CustomGroup" Header="DED Lines" Foreground="#AAAAAA"
                                          BorderBrush="#3F3F46" Margin="0,0,0,10" Visibility="Collapsed">
                                    <ItemsControl x:Name="LineEditors">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type local:LineEditorViewModel}">
                                                <Border BorderBrush="#3F3F46" BorderThickness="0,0,0,1" Padding="4,6">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="54"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>

                                                        <TextBlock Grid.Column="0" Text="{Binding DisplayName}"
                                                                   Foreground="#AAAAAA" VerticalAlignment="Top"
                                                                   Margin="0,4,0,0" FontSize="11"/>

                                                        <StackPanel Grid.Column="1">
                                                            <!-- Token chips -->
                                                            <ItemsControl ItemsSource="{Binding Chips}">
                                                                <ItemsControl.ItemsPanel>
                                                                    <ItemsPanelTemplate>
                                                                        <WrapPanel/>
                                                                    </ItemsPanelTemplate>
                                                                </ItemsControl.ItemsPanel>
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate DataType="{x:Type local:TokenChipViewModel}">
                                                                        <Border Style="{StaticResource TokenChip}">
                                                                            <StackPanel Orientation="Horizontal">
                                                                                <TextBlock Text="{Binding Label}"
                                                                                           Foreground="#DDDDDD" FontSize="11"
                                                                                           VerticalAlignment="Center"/>
                                                                                <Button Content="×"
                                                                                        Command="{Binding RemoveCommand}"
                                                                                        Background="Transparent"
                                                                                        BorderThickness="0"
                                                                                        Foreground="#888"
                                                                                        FontSize="10"
                                                                                        Padding="3,0,0,1"
                                                                                        Cursor="Hand"/>
                                                                            </StackPanel>
                                                                        </Border>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>

                                                            <!-- Add token row -->
                                                            <StackPanel Orientation="Horizontal" Margin="2,4,0,0">
                                                                <ComboBox ItemsSource="{Binding AvailableAliases}"
                                                                          SelectedItem="{Binding SelectedOption}"
                                                                          DisplayMemberPath="Label"
                                                                          Width="110" FontSize="11"
                                                                          Background="#2D2D2D"/>
                                                                <!-- Separator text input -->
                                                                <StackPanel Orientation="Horizontal"
                                                                            Visibility="{Binding IsNewSeparator, Converter={StaticResource BoolToVis}}"
                                                                            Margin="4,0">
                                                                    <TextBlock Text="Text:" Foreground="#AAAAAA"
                                                                               VerticalAlignment="Center" Margin="0,0,4,0"
                                                                               FontSize="11"/>
                                                                    <TextBox Text="{Binding NewSeparatorText, UpdateSourceTrigger=PropertyChanged}"
                                                                             Width="70" FontSize="11"
                                                                             FontFamily="Consolas"
                                                                             ToolTip="Separator text — spaces and any characters, e.g. '  ' or ' | '"/>
                                                                </StackPanel>
                                                                <Button Content="＋" Command="{Binding AddTokenCommand}"
                                                                        Padding="6,2" Margin="4,0,0,0"
                                                                        Background="#0E639C" Foreground="White"
                                                                        BorderThickness="0" FontSize="11"/>
                                                            </StackPanel>
                                                        </StackPanel>

                                                        <!-- Width indicator -->
                                                        <TextBlock Grid.Column="2" Text="{Binding WidthText}"
                                                                   Foreground="{Binding WidthBrush}"
                                                                   VerticalAlignment="Center"
                                                                   Margin="8,0,0,0" FontSize="11"
                                                                   FontFamily="Consolas" Width="70"
                                                                   TextAlignment="Right"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </GroupBox>

                                <!-- DED Preview -->
                                <GroupBox Header="Preview (sample data)" Foreground="#AAAAAA"
                                          BorderBrush="#3F3F46" Margin="0,0,0,4">
                                    <StackPanel Margin="4,4">
                                        <Image x:Name="PreviewImage" Width="400" Height="130"
                                               RenderOptions.BitmapScalingMode="NearestNeighbor"
                                               HorizontalAlignment="Left"
                                               SnapsToDevicePixels="True"/>
                                    </StackPanel>
                                </GroupBox>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <!-- ════════════════ Tab 2: Fields Catalog ════════════════ -->
            <TabItem Header="Fields Catalog">
                <DockPanel Background="#1E1E1E">

                    <!-- Toolbar -->
                    <Border DockPanel.Dock="Top" Padding="12,8" Background="#252526"
                            BorderBrush="#3F3F46" BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="＋ Add Field" Click="AddField_Click" Padding="10,4"
                                    Background="#0E639C" Foreground="White" BorderThickness="0" Margin="0,0,8,0"/>
                            <Button Content="Browse DCS Fields…" Click="BrowseFields_Click"
                                    Style="{StaticResource ActionButton}"
                                    IsEnabled="{Binding HasSnapshot, RelativeSource={RelativeSource AncestorType=Window}}"
                                    Padding="10,4" Background="#3F3F46"/>
                        </StackPanel>
                    </Border>

                    <!-- Inline add/edit panel -->
                    <Border x:Name="FieldEditPanel" DockPanel.Dock="Bottom" Visibility="Collapsed"
                            Background="#252526" Padding="12,8"
                            BorderBrush="#3F3F46" BorderThickness="0,1,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="Alias:" Foreground="#AAAAAA"
                                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBox x:Name="EditAlias" Grid.Column="1"
                                     Background="#2D2D2D" Foreground="White"
                                     BorderBrush="#555" Padding="4,3"/>

                            <TextBlock Grid.Column="2" Text="DCS Key:" Foreground="#AAAAAA"
                                       VerticalAlignment="Center" Margin="12,0,6,0"/>
                            <TextBox x:Name="EditKey" Grid.Column="3"
                                     Background="#2D2D2D" Foreground="White"
                                     BorderBrush="#555" Padding="4,3"/>

                            <TextBlock Grid.Column="4" Text="Format:" Foreground="#AAAAAA"
                                       VerticalAlignment="Center" Margin="12,0,6,0"/>
                            <TextBox x:Name="EditFormat" Grid.Column="5"
                                     Background="#2D2D2D" Foreground="White"
                                     BorderBrush="#555" Padding="4,3" FontFamily="Consolas"
                                     TextChanged="EditFormat_TextChanged"
                                     ToolTip="%XXX% integer  |  %XXX.XXX% float  |  %SSSSS% string  |  %B% ON/OFF"/>

                            <TextBlock Grid.Column="6" Text="W:" Foreground="#AAAAAA"
                                       VerticalAlignment="Center" Margin="8,0,4,0"/>
                            <TextBlock x:Name="EditWidthPreview" Grid.Column="7"
                                       Foreground="#AAAAAA" VerticalAlignment="Center"
                                       FontFamily="Consolas"/>

                            <TextBlock Grid.Column="8" Text="Sample:" Foreground="#AAAAAA"
                                       VerticalAlignment="Center" Margin="12,0,6,0"/>
                            <TextBox x:Name="EditSample" Grid.Column="9"
                                     Background="#2D2D2D" Foreground="#AAAAAA"
                                     BorderBrush="#555" Padding="4,3" FontFamily="Consolas"
                                     ToolTip="Representative value shown in preview when DCS is not running"/>

                            <StackPanel Grid.Column="10" Orientation="Horizontal" Margin="8,0,0,0">
                                <Button Content="Save" Click="SaveField_Click" Padding="10,4"
                                        Background="#0E639C" Foreground="White" BorderThickness="0" Margin="0,0,6,0"/>
                                <Button Content="Cancel" Click="CancelField_Click" Padding="10,4"
                                        Background="#3F3F46" Foreground="White" BorderThickness="0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Fields list (DataGrid) -->
                    <DataGrid x:Name="FieldsGrid"
                              Background="#1E1E1E" Foreground="#CCCCCC"
                              BorderThickness="0"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#2D2D2D"
                              RowBackground="#1E1E1E"
                              AlternatingRowBackground="#222222"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              HeadersVisibility="Column"
                              CellStyle="{StaticResource DarkCell}">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#2D2D2D"/>
                                <Setter Property="Foreground" Value="#AAAAAA"/>
                                <Setter Property="Padding" Value="8,4"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="BorderBrush" Value="#3F3F46"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Alias"  Binding="{Binding Alias}"  Width="90"/>
                            <DataGridTextColumn Header="DCS Key" Binding="{Binding Key}"   Width="*"/>
                            <DataGridTextColumn Header="Format" Binding="{Binding Format}" Width="200">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontFamily" Value="Consolas"/>
                                        <Setter Property="Foreground" Value="#DDDDDD"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Width" Binding="{Binding Width}"   Width="55"/>
                            <DataGridTemplateColumn Header="" Width="80">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <Button Content="✎" Click="EditFieldRow_Click"
                                                    ToolTip="Edit" Padding="4,1" Margin="0,0,3,0"
                                                    Background="#3F3F46" Foreground="White" BorderThickness="0"
                                                    Tag="{Binding}"/>
                                            <Button Content="✗" Click="DeleteFieldRow_Click"
                                                    ToolTip="Delete" Padding="4,1"
                                                    Background="#6B2020" Foreground="White" BorderThickness="0"
                                                    Tag="{Binding}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>
        </TabControl>

        <!-- ── Footer ──────────────────────────────────────────────────── -->
        <Border Grid.Row="3" Background="#252526" BorderBrush="#3F3F46"
                BorderThickness="0,1,0,0" Padding="12,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Unlisted aircraft:" Foreground="#AAAAAA"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox x:Name="DefaultModeCombo" Grid.Column="1" Width="180"
                          SelectionChanged="DefaultModeCombo_SelectionChanged">
                    <ComboBoxItem Tag="Default">Show default layout</ComboBoxItem>
                    <ComboBoxItem Tag="Skip">Skip (do nothing)</ComboBoxItem>
                </ComboBox>

                <TextBlock x:Name="ConfigPathLabel" Grid.Column="2" Foreground="#555"
                           VerticalAlignment="Center" HorizontalAlignment="Center"
                           FontSize="10"/>

                <StackPanel Grid.Column="3" Orientation="Horizontal">
                    <Button Content="Reload" Click="Reload_Click" Padding="12,4" Margin="0,0,6,0"
                            Background="#3F3F46" Foreground="White" BorderThickness="0"/>
                    <Button Content="Save" Click="Save_Click" Padding="12,4"
                            Background="#0E639C" Foreground="White" BorderThickness="0"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
